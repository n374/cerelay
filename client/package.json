{
  "name": "cerelay-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cerelay": "dist/index.js"
  },
  "scripts": {
    "prestart": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "install:global": "bash scripts/install-global.sh",
    "uninstall:global": "rm -rf ~/.local/lib/cerelay ~/.local/bin/cerelay && echo 'Uninstalled cerelay'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/ws": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
