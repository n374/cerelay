{
  "name": "cerelay-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cerelay": "dist/index.js"
  },
  "scripts": {
    "prestart": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --banner:js='import{createRequire}from\"module\";const require=createRequire(import.meta.url);' --outfile=dist/cerelay-bundle.mjs",
    "bundle:docker": "bash scripts/bundle-docker.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "install:global": "bash scripts/install-global.sh",
    "uninstall:global": "rm -rf ~/.local/lib/cerelay ~/.local/bin/cerelay && echo 'Uninstalled cerelay'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.3",
    "commander": "^12.0.0",
    "http-proxy-agent": "^9.0.0",
    "https-proxy-agent": "^9.0.0",
    "smol-toml": "^1.6.1",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/ws": "latest",
    "esbuild": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
