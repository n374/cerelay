{
  "name": "cerelay",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "typecheck": "npm run typecheck:workspaces",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present",
    "test:smoke": "node --test test/**/*.test.mjs",
    "test:workspaces": "npm run test --workspaces --if-present",
    "server:up": "docker compose up --build --force-recreate --remove-orphans -d",
    "server:down": "docker compose down",
    "server:logs": "docker compose logs -f cerelay-server",
    "test": "sh ./test/run-host-tests.sh",
    "test:e2e": "sh ./test/run-e2e-comprehensive.sh",
    "test:e2e:meta": "sh ./test/run-e2e-comprehensive-meta.sh",
    "test:container": "sh ./test/run-container-tests.sh",
    "test:gc": "sh ./test/gc-test-resources.sh",
    "test:gc:all": "sh ./test/gc-test-resources.sh --all"
  },
  "workspaces": ["server", "client", "web"]
}
