{
  "permissions": {
    "deny": [
      "Edit(.env*)",
      "Edit(secrets/**)",
      "Write(.env*)",
      "Write(secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/proxy/dispatch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/proxy/audit-post.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
