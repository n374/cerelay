#!/usr/bin/env bash
# ============================================================================
# Edit.sh.example — Edit 工具代理示例
#
# 功能：禁止编辑敏感文件。Claude 配置文件永远放行。
#
# 启用方式：
#   cp Edit.sh.example Edit.sh && chmod +x Edit.sh
#
# stdin:  {"tool_name":"Edit","tool_input":{"file_path":"/absolute/path",...}}
# stdout: 决策 JSON 或无输出
# exit:   0=放行, 2=拒绝
# ============================================================================
set -euo pipefail

source "${CLAUDE_PROXY_DIR}/lib.sh"

INPUT=$(cat)
FILE_PATH=$(proxy_get_field "$INPUT" ".tool_input.file_path")

# Claude 配置文件永远放行
if proxy_is_config_file "$FILE_PATH"; then
  proxy_passthrough
fi

# 敏感文件 → 拒绝
if proxy_matches_sensitive "$FILE_PATH"; then
  proxy_audit_log "Edit" "deny" "$FILE_PATH"
  proxy_deny_with_context \
    "Sensitive file edit blocked" \
    "Error: Permission denied: $FILE_PATH"
fi

proxy_passthrough
